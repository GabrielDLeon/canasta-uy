# ==========================================
# CanastaUY - Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# ==========================================

# Required - JWT Secret (Base64 encoded, min 256 bits)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Database Configuration
# For local development: localhost
# For Docker: postgres (service name)
DATABASE_URL=jdbc:postgresql://localhost:5432/canastauy
DATABASE_USER=canastauy_user
DATABASE_PASSWORD=canastauy_pass
DATABASE_DB=canastauy

# Redis Configuration
# For local development: localhost
# For Docker: redis (service name)
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Optional - pgAdmin credentials
PGADMIN_EMAIL=admin@canasta.uy
PGADMIN_PASSWORD=admin
